{% extends 'base.html.twig' %}

{% block title %}Produktu katalogs - Epclone{% endblock %}

{% block body %}
<div class="container mt-4">
    {# Блок для вывода уведомлений #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <h1 class="mb-4 fw-bold">Produktu katalogs</h1>

    <div class="row">
        
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm p-3 bg-white">
                <h5 class="fw-bold mb-3">Kategorijas</h5>
                <div class="list-group">
                    <a href="{{ path('app_catalog') }}" class="list-group-item list-group-item-action {% if currentCategory is empty %}active{% endif %}">
                        Visas preces
                    </a>
                    {% for category in categories %}
                        {# Используем точные свойства .code и .name из сущности Category #}
                        <a href="{{ path('app_catalog', {'category': category.code}) }}" class="list-group-item list-group-item-action {% if currentCategory == category.code %}active{% endif %}">
                            {{ category.name }}
                        </a>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="row row-cols-1 row-cols-md-3 g-4">
                {% for product in products %}
                    <div class="col">
                        <div class="card h-100 shadow-sm d-flex flex-column">
                            
                            <a href="{{ path('app_product_show', { id: product.id }) }}" class="text-center p-3 d-block">
                                {% if product.image %}
                                    <img src="{{ asset('uploads/images/' ~ product.image) }}" class="card-img-top img-fluid" alt="{{ product.name }}" style="max-height: 180px; object-fit: contain;">
                                {% else %}
                                    <div class="bg-light text-center text-muted py-5" style="height: 180px; line-height: 140px;">Nav attēla</div>
                                {% endif %}
                            </a>

                            <div class="card-body d-flex flex-column justify-content-between">
                                <div>
                                    <h5 class="card-title mb-1">
                                        <a href="{{ path('app_product_show', { id: product.id }) }}" class="text-dark text-decoration-none fw-bold">
                                            {{ product.name }}
                                        </a>
                                    </h5>
                                    
                                    <p class="text-muted small mb-2">Kods: {{ product.uniqueCode }}</p>
                                    
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="fs-5 fw-bold text-primary">{{ product.price }} €</span>
                                        
                                        <span class="badge {{ product.stock > 0 ? 'bg-success' : 'bg-danger' }}">
                                            {{ product.stock > 0 ? 'Ir noliktavā (' ~ product.stock ~ ')' : 'Nav pieejams' }}
                                        </span>
                                    </div>
                                </div>

                                <div class="mt-auto">
                                    <a href="{{ path('app_cart_add', { id: product.id }) }}" class="btn btn-primary w-100 {% if product.stock == 0 %}disabled{% endif %}">
                                        Ielikt grozā
                                    </a>
                                </div>
                            </div>

                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>

    </div>
</div>
{% endblock %}