{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} - Epclone{% endblock %}

{% block body %}
<div class="container mt-4">
    <a href="{{ path('app_catalog') }}" class="btn btn-sm btn-outline-secondary mb-4">← Atpakaļ uz katalogu</a>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card p-4 text-center shadow-sm">
                {% if product.image %}
                    <img src="{{ asset('uploads/images/' ~ product.image) }}" class="img-fluid" alt="{{ product.name }}" style="max-height: 400px; object-fit: contain;">
                {% else %}
                    <div class="bg-light text-center py-5 text-muted" style="height: 300px; line-height: 200px;">Nav attēla</div>
                {% endif %}
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <h1 class="fw-bold mb-2">{{ product.name }}</h1>
            <p class="text-muted mb-3">Preces kods: <span class="badge bg-secondary">{{ product.uniqueCode }}</span></p>
            
            <div class="card p-4 shadow-sm bg-white mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="fs-2 fw-bold text-primary">{{ product.price }} €</span>
                    <span class="badge fs-6 {{ product.stock > 0 ? 'bg-success' : 'bg-danger' }}">
                        {{ product.stock > 0 ? 'Ir noliktavā (' ~ product.stock ~ ')' : 'Nav pieejams' }}
                    </span>
                </div>

                <a href="{{ path('app_cart_add', { id: product.id }) }}" class="btn btn-primary btn-lg w-100 {% if product.stock == 0 %}disabled{% endif %}">
                     Ielikt grozā
                </a>
            </div>

            <h5>Apraksts un specifikācija</h5>
            <div class="border rounded p-3 bg-white">
                <p class="mb-0">{{ product.description|raw }}</p>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-8">
            <div class="card shadow-sm p-4 mb-4">
                <h4 class="fw-bold mb-4">Klientu atsauksmes</h4>

                {% set approved_reviews = 0 %}
                {% for review in product.reviews %}
                    {% if review.statuss == 'approved' or review.statuss == '1' %}
                        {% set approved_reviews = approved_reviews + 1 %}
                        <div class="border-bottom pb-3 mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <strong>{{ review.user.firstName }} {{ review.user.lastName }}</strong>
                                <span class="text-warning fs-5">
                                    {% for i in 1..5 %}
                                        {{ i <= review.rating ? '★' : '☆' }}
                                    {% endfor %}
                                </span>
                            </div>
                            <small class="text-muted d-block mb-2">{{ review.createdAt|date('d.m.Y H:i') }}</small>
                            <p class="mb-0 bg-light p-3 rounded text-secondary">{{ review.description }}</p>
                        </div>
                    {% endif %}
                {% endfor %}

                {% if approved_reviews == 0 %}
                    <div class="alert alert-light text-center py-4 mb-0">
                        <p class="text-muted mb-0">Šai precei vēl nav pievienotu atsauksmju. Esiet pirmais!</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm p-4 position-sticky" style="top: 20px;">
                <h5 class="fw-bold mb-3">Pievienot atsauksmi</h5>
                
                {% if app.user %}
                    <form action="{{ path('app_product_review_add', { id: product.id }) }}" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Jūsu vērtējums</label>
                            <select name="vertejums" class="form-select" required>
                                <option value="">Izvēlieties vērtējumu...</option>
                                <option value="5">5 ★★★★★ (Izcili)</option>
                                <option value="4">4 ★★★★ (Labi)</option>
                                <option value="3">3 ★★★ (Vidēji)</option>
                                <option value="2">2 ★★ (Slikti)</option>
                                <option value="1">1 ★ (Ļoti slikti)</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Komentārs</label>
                            <textarea name="apraksts" class="form-control" rows="4" placeholder="Uzrakstiet savu pieredzi..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-outline-primary w-100">Iesniegt atsauksmi</button>
                    </form>
                {% else %}
                    <div class="text-center py-3">
                        <p class="text-muted small">Tikai reģistrēti lietotāji var atstāt atsauksmes.</p>
                        <a href="/login" class="btn btn-sm btn-primary px-4">Ienākt sistēmā</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}