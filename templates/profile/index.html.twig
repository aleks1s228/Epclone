{% extends 'base.html.twig' %}

{% block title %}Mans profils - Epclone{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm p-4 mb-4">
                <h4 class="mb-3">Lietotāja profils</h4>
                <hr>
                <p><strong>E-pasts:</strong> {{ user.email }}</p>
                <a href="/logout" class="btn btn-sm btn-outline-danger w-100 mt-3">Iziet no sistēmas</a>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm p-4">
                <h4 class="mb-4">Pasūtījumu vēsture</h4>

                {% if orders is empty %}
                    <div class="alert alert-light text-center py-4">
                        <p class="text-muted mb-0">Jūs vēl neesat veicis nevienu pasūtījumu.</p>
                    </div>
                {% else %}
                    <div class="accordion" id="ordersAccordion">
                        {% for order in orders %}
                            <div class="accordion-item mb-3 border shadow-sm rounded">
                                <h2 class="accordion-header" id="heading{{ order.id }}">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ order.id }}">
                                        <div class="d-flex w-100 justify-content-between align-items-center me-3">
                                            <div>
                                                <strong>Pasūtījums #{{ order.id }}</strong>
                                                <span class="text-muted small ms-2">({{ order.createdAt|date('d.m.Y H:i') }})</span>
                                            </div>
                                            <div>
                                                <span class="fs-6 fw-bold text-primary me-3">{{ order.totalPrice }} €</span>
                                                
                                                {# ИСПРАВЛЕННЫЙ SPAN НИЖЕ #}
                                                <span class="badge 
                                                    {% if order.status.value == 'new' %}bg-warning text-dark
                                                    {% elseif order.status.value == 'completed' %}bg-success
                                                    {% else %}bg-secondary{% endif %}">
                                                    {{ order.status.value|upper }}
                                                </span>
                                            </div>
                                        </div>
                                    </button>
                                </h2>
                                <div id="collapse{{ order.id }}" class="accordion-collapse collapse" data-bs-parent="#ordersAccordion">
                                    <div class="accordion-body bg-white">
                                        <h5>Preču saraksts:</h5>
                                        <table class="table table-sm align-middle">
                                            <thead>
                                                <tr>
                                                    <th>Prece</th>
                                                    <th>Skaits</th>
                                                    <th>Cena</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {% for item in order.orderItems %}
                                                    <tr>
                                                        <td>{{ item.product ? item.product.name : 'Prece dzēsta' }}</td>
                                                        <td>{{ item.quantity }} x</td>
                                                        <td>{{ item.price }} €</td>
                                                    </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                        <div class="mt-3 text-muted small">
                                            <strong>Piegādes dati:</strong> {{ order.customerEmail }}, {{ order.deliveryPhone }}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}